{
  "id": "dead-mans-switch",
  "name": "Check-In Switch",
  "version": "1.0.1",
  "description": "A dead-man's switch for peace of mind: check in on your schedule, and if you go silent past your chosen interval, the people you designate get an alert with your message and a link to any files you left for them.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "general",
  "tags": [
    "safety",
    "check-in",
    "alerts"
  ],
  "data_access": {
    "reads": [
      "family.members",
      "app.contacts.contact_emails"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "switches": {
      "kind": "owner_only",
      "member_column": "member_id",
      "adults_bypass": false
    }
  },
  "icon": "🛟",
  "nav": {
    "label": "Check-In Switch"
  },
  "required_capabilities": [
    "cron",
    "email"
  ],
  "inactivity_alerts": {
    "table": "switches",
    "member_column": "member_id",
    "id_column": "id",
    "active_column": "active",
    "interval_hours_column": "interval_hours",
    "last_checkin_column": "last_checkin_at",
    "last_alerted_column": "last_alerted_at",
    "message_column": "message",
    "recipients_column": "recipient_member_ids",
    "external_recipients_column": "recipient_emails",
    "share_item_type": "switch"
  },
  "external_contacts": {},
  "file_acls": {
    "read": "uploader_only"
  },
  "shareable": {
    "switch": {
      "table": "switches",
      "title_column": "label",
      "owner_column": "member_id",
      "columns": [
        {
          "column": "message",
          "label": "Message",
          "format": "multiline"
        }
      ],
      "files": {
        "ids_column": "attachment_file_ids",
        "label": "Files left for you"
      }
    }
  },
  "kiosk": "never"
}
